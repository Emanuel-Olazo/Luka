<navigation
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:id="@+id/nav_graph"
app:startDestination="@id/dashboardFragment" >
<fragment
    android:id="@+id/dashboardFragment"
    android:name="com.luka.finanzas.ui.dashboard.DashboardFragment"
    android:label="Inicio" />
<fragment
    android:id="@+id/transactionsFragment"
    android:name="com.luka.finanzas.ui.transactions.TransactionsFragment"
    android:label="Transacciones" >

    <action
        android:id="@+id/action_transactions_to_add"
        app:destination="@id/addTransactionFragment" />

</fragment>
<fragment
    android:id="@+id/addTransactionFragment"
    android:name="com.luka.finanzas.ui.transactions.AddTransactionFragment"
    android:label="Nueva transacción" />
<fragment
    android:id="@+id/budgetFragment"
    android:name="com.luka.finanzas.ui.budget.BudgetFragment"
    android:label="Presupuesto" />
<fragment
    android:id="@+id/savingsFragment"
    android:name="com.luka.finanzas.ui.savings.SavingsFragment"
    android:label="Alcancías" >

    <action
        android:id="@+id/action_savings_to_add"
        app:destination="@id/addSavingsGoalFragment" />

</fragment>
<fragment
    android:id="@+id/addSavingsGoalFragment"
    android:name="com.luka.finanzas.ui.savings.AddSavingsGoalFragment"
    android:label="Nueva alcancía" />
</navigation>