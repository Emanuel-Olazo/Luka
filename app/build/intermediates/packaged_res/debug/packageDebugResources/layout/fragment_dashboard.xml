<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Fondo oscuro superior -->
            <View
                android:id="@+id/headerBackground"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="#1E2240"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOLA, USUARIO"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="56dp"
                android:layout_marginStart="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvBalanceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SALDO DISPONIBLE"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@+id/tvWelcome"
                app:layout_constraintStart_toStartOf="@+id/tvWelcome"/>

            <TextView
                android:id="@+id/tvBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="40sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                tools:text="S/. 0.00"
                app:layout_constraintTop_toBottomOf="@+id/tvBalanceLabel"
                app:layout_constraintStart_toStartOf="@+id/tvWelcome"/>

            <!-- Divider -->
            <View
                android:id="@+id/headerDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:background="#374151"
                app:layout_constraintTop_toBottomOf="@+id/tvBalance"/>

            <!-- Ingresos Indicator -->
            <View
                android:id="@+id/dotIncome"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/circle_primary"
                android:backgroundTint="#34D399"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@+id/headerDivider"
                app:layout_constraintStart_toStartOf="@+id/tvWelcome"
                app:layout_constraintBottom_toBottomOf="@+id/tvTotalIncomeLabel"/>

            <TextView
                android:id="@+id/tvTotalIncomeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingresos: "
                android:textColor="#D1D5DB"
                android:textSize="13sp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@+id/headerDivider"
                app:layout_constraintStart_toEndOf="@+id/dotIncome"/>

            <TextView
                android:id="@+id/tvTotalIncome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="S/. 0.00"
                app:layout_constraintTop_toTopOf="@+id/tvTotalIncomeLabel"
                app:layout_constraintStart_toEndOf="@+id/tvTotalIncomeLabel"/>

            <!-- Resumen del Período -->
            <TextView
                android:id="@+id/tvResumenLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESUMEN DEL PERÍODO"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@+id/tvTotalIncomeLabel"
                app:layout_constraintStart_toStartOf="@+id/tvWelcome"/>

            <HorizontalScrollView
                android:id="@+id/svResumen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@+id/tvResumenLabel">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Tarjeta Gastos -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="140dp"
                        android:layout_height="120dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        android:layout_marginEnd="12dp"
                        android:layout_marginVertical="4dp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:background="@color/white">
                            
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:text="GASTOS"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:textColor="#9CA3AF"/>
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@android:drawable/arrow_down_float"
                                    app:tint="#EF4444"
                                    android:background="@drawable/bg_icon_rounded"
                                    android:backgroundTint="#FEE2E2"
                                    android:padding="4dp"/>
                            </LinearLayout>
                            
                            <TextView
                                android:id="@+id/tvTotalExpense"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="bottom|start"
                                android:textColor="#EF4444"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="S/. 0.00"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Tarjeta Pagos -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="140dp"
                        android:layout_height="120dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        android:layout_marginEnd="12dp"
                        android:layout_marginVertical="4dp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:background="@color/white">
                            
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:text="PAGOS"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:textColor="#9CA3AF"/>
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@android:drawable/ic_menu_agenda"
                                    app:tint="#3B82F6"
                                    android:background="@drawable/bg_icon_rounded"
                                    android:backgroundTint="#DBEAFE"
                                    android:padding="4dp"/>
                            </LinearLayout>
                            
                            <TextView
                                android:id="@+id/tvTotalPayments"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="bottom|start"
                                android:textColor="#3B82F6"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="S/. 0.00"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Tarjeta Ingresos -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="140dp"
                        android:layout_height="120dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        android:layout_marginVertical="4dp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:background="@color/white">
                            
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:text="INGRESOS"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:textColor="#9CA3AF"/>
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@android:drawable/arrow_up_float"
                                    app:tint="#10B981"
                                    android:background="@drawable/bg_icon_rounded"
                                    android:backgroundTint="#D1FAE5"
                                    android:padding="4dp"/>
                            </LinearLayout>
                            
                            <TextView
                                android:id="@+id/tvTotalIncomeCard"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="bottom|start"
                                android:textColor="#10B981"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="S/. 0.00"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Movimientos Recientes -->
            <TextView
                android:id="@+id/tvRecentLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Movimientos Recientes"
                android:textColor="#1F2937"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@+id/svResumen"
                app:layout_constraintStart_toStartOf="@+id/tvWelcome"/>

            <TextView
                android:id="@+id/tvVerTodas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver todos >"
                android:textColor="#3B82F6"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                app:layout_constraintTop_toTopOf="@+id/tvRecentLabel"
                app:layout_constraintBottom_toBottomOf="@+id/tvRecentLabel"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="16dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="100dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@+id/tvRecentLabel"
                app:layout_constraintBottom_toBottomOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/white"
                    android:padding="16dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecentTransactions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>
                        
                    <!-- Empty State for RecyclerView (handled in code or logic, but we can put a placeholder layout if we wanted) -->

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>